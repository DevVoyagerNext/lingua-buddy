# 应用运行环境与端口
APP_ENV=development
HTTP_PORT=8080

# 安全密钥（必填，非空）：缺失会导致登录与单词题目令牌签名无法工作
# 生成方式示例：openssl rand -hex 32
JWT_ACCESS_SECRET=
QUESTION_TOKEN_SECRET=

# 内部数据库
DB_USER=root
DB_PASSWORD=your_password
DB_ADDR=127.0.0.1:3306
DB_NAME=lingua

# Redis 缓存与限流（MVP 可不启用；要真正使用请把 REDIS_ENABLED 改为 true）
REDIS_ENABLED=false
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# 邮件：QQ 邮箱 SMTP（基础设施保留，当前注册未使用，预留未来邮箱验证/找回密码）
# MAIL_PASSWORD 填 QQ 邮箱授权码（非登录密码）
MAIL_PROVIDER=qq_smtp
MAIL_SMTP_HOST=smtp.qq.com
MAIL_SMTP_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_CODE_TTL_MINUTES=10
MAIL_RESEND_INTERVAL_SECONDS=60

# 文件存储：UPLOAD_STORAGE 只影响非音频普通文件（local/aliyun_oss）。
# 注意：语音识别（Paraformer 录音文件识别）异步且需要公网可访问的音频 URL，
# 因此音频无论开发/生产都固定走 OSS（详见 docs/04 第 5.3/5.5 节），不受本开关影响。
UPLOAD_STORAGE=local
UPLOAD_DIR=./uploads
OBJECT_STORAGE_PROVIDER=aliyun_oss
OBJECT_STORAGE_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OBJECT_STORAGE_REGION=oss-cn-beijing
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# AI：阿里云通义千问（DashScope，OpenAI 兼容模式）
AI_PROVIDER=aliyun_dashscope
AI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_API_KEY=
AI_MODEL=qwen-plus

# ASR 语音识别：阿里云 DashScope Paraformer（录音文件识别，异步，需公网音频 URL → 走 OSS）
ASR_PROVIDER=aliyun_dashscope
ASR_API_BASE=https://dashscope.aliyuncs.com/api/v1
ASR_API_KEY=
ASR_MODEL=paraformer-v2

# TTS 语音合成（P2）：阿里云 DashScope CosyVoice（仅 WebSocket）
TTS_PROVIDER=aliyun_dashscope
TTS_API_BASE=wss://dashscope.aliyuncs.com/api-ws/v1/inference
TTS_API_KEY=
TTS_MODEL=cosyvoice-v2
TTS_VOICE=longxiaochun_v2

# 外刊文章：VOA Learning English RSS（每天北京时间 07:00 同步）
ARTICLE_SOURCE=voa_learning_english
ARTICLE_FEED_URLS=https://learningenglish.voanews.com/podcast/?zoneId=1689&format=RSS
ARTICLE_SYNC_CRON=0 0 7 * * *
ARTICLE_SYNC_TIMEZONE=Asia/Shanghai
